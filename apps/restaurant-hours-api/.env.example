TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NGROK_AUTHTOKEN=your-ngrok-authtoken
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# Copy the Convex values that already exist in your local `.env.local`.
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
CONVEX_SITE_URL=https://your-site.convex.site

# Optional: override Langfuse local bootstrap keys if you do not want the defaults.
LANGFUSE_PUBLIC_KEY=pk-lf-local-public-key
LANGFUSE_SECRET_KEY=sk-lf-local-secret-key
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_BASEURL=http://localhost:3000
LANGFUSE_TRACING_ENVIRONMENT=docker-local

# Optional: override these before exposing Langfuse outside local development.
LANGFUSE_NEXTAUTH_SECRET=restaulang-nextauth-secret
LANGFUSE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
LANGFUSE_SALT=restaulang-local-salt
