# =============================================================================
# LOCAL ENV FILES GUIDE
# =============================================================================
# .env.local   -> recommended and only active local runtime file for normal development.
# .env.example -> committed template/reference for expected variables/defaults.
#
# Recommended local setup (single-file convention):
# 1) Copy this file to `.env.local`.
# 2) Set all local values/secrets in `.env.local`.

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NGROK_AUTHTOKEN=your-ngrok-authtoken
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# Copy the Convex values that already exist in your local `.env.local`.
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
CONVEX_SITE_URL=https://your-site.convex.site

# =============================================================================
# SECURITY CONFIGURATION (Phase 2 - Required for Production)
# =============================================================================

# SEC-01: Telegram webhook signature validation
# Generate a secure random string and set it both here and in your Telegram bot webhook configuration
# Use: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your-secure-webhook-secret-token

# SEC-02: JWT authentication for admin routes
# Secret key for signing and verifying JWT tokens
# Use: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key

# JWT token expiration time (default: 24h)
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRES_IN=24h

# SEC-06: CORS allowed origins (comma-separated)
# List all domains that should be allowed to make cross-origin requests
# Example: https://example.com,https://admin.example.com
ALLOWED_ORIGINS=https://your-frontend-domain.com

# =============================================================================
# Optional: Langfuse Configuration
# =============================================================================

# Optional: override Langfuse local bootstrap keys if you do not want the defaults.
LANGFUSE_PUBLIC_KEY=pk-lf-local-public-key
LANGFUSE_SECRET_KEY=sk-lf-local-secret-key
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_BASEURL=http://localhost:3000
# Recommended default: keep "auto" to let runtime resolve tracing environment dynamically:
# - judge for AI-as-a-judge runs
# - dev for localhost/127.0.0.1 requests
# - prod for non-local hosts
LANGFUSE_TRACING_ENVIRONMENT=auto
LANGFUSE_JUDGE_DATASET_NAME=judge-test-battery

# Optional: custom model pricing for cost calculation when using models not built into Langfuse.
# Prices are in USD per TOKEN (or per selected unit). If you prefer per-1M inputs, use *_PER_1M.
LANGFUSE_MODEL_PRICING_MODEL_NAME=gemma-3-27b-it
LANGFUSE_MODEL_PRICING_UNIT=TOKENS
LANGFUSE_MODEL_PRICING_MATCH_PATTERN=(?i)^(gemma-3-27b-it)$
LANGFUSE_MODEL_PRICING_INPUT_PRICE_PER_1M=0
LANGFUSE_MODEL_PRICING_OUTPUT_PRICE_PER_1M=0
# Alternative advanced mode (JSON array). Example:
# LANGFUSE_MODEL_PRICING_JSON=[{"modelName":"gemma-3-27b-it","matchPattern":"(?i)^(gemma-3-27b-it)$","unit":"TOKENS","inputPricePer1M":0,"outputPricePer1M":0}]

# Optional: override these before exposing Langfuse outside local development.
LANGFUSE_NEXTAUTH_SECRET=restaulang-nextauth-secret
LANGFUSE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
LANGFUSE_SALT=restaulang-local-salt

# =============================================================================
# RESILIENCE CONFIGURATION (Phase 3 - Circuit Breakers)
# =============================================================================

# RES-01: Circuit Breaker for Gemini API
# Number of consecutive failures before opening the circuit (default: 5)
GEMINI_CIRCUIT_FAILURE_THRESHOLD=5
# Time in milliseconds to wait before attempting reset (default: 30000)
GEMINI_CIRCUIT_RESET_TIMEOUT_MS=30000

# RES-02: Circuit Breaker for Convex
# Number of consecutive failures before opening the circuit (default: 3)
CONVEX_CIRCUIT_FAILURE_THRESHOLD=3
# Time in milliseconds to wait before attempting reset (default: 15000)
CONVEX_CIRCUIT_RESET_TIMEOUT_MS=15000

# =============================================================================
# LOGGING CONFIGURATION (Phase 3 - Structured Logging)
# =============================================================================

# RES-03: Log level and format
# Valid levels: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO
# Valid formats: json, pretty (default: json in production, pretty in development)
LOG_FORMAT=pretty

# =============================================================================
# LANGFUSE RELEASE CONFIGURATION
# =============================================================================

# Optional: Release version for trace attribution
LANGFUSE_RELEASE=1.0.0

# =============================================================================
# SERVER CONFIGURATION (Phase 4 - Production Hardening)
# =============================================================================

# PROD-01: Graceful shutdown timeout in milliseconds (default: 30000)
# Time to wait for active connections to complete before forcing exit
SHUTDOWN_TIMEOUT_MS=30000

# =============================================================================
# SECURITY CONFIGURATION (Phase 4 - Advanced)
# =============================================================================

# SEC-09: Trusted proxy IP addresses for rate limiting (comma-separated)
# Only trust X-Forwarded-For and X-Real-IP headers when the request comes
# from a trusted proxy (e.g., load balancer, reverse proxy, nginx).
# SECURITY: Without this, attackers can spoof IPs to bypass rate limits.
# Example: 10.0.0.1,172.16.0.1,192.168.1.1
# Default: empty (no proxies trusted - uses socket IP only)
TRUSTED_PROXIES=

# SEC-07: Token version store backend for distributed deployments
# Options: memory (single-instance), convex (distributed/clustered)
# Default: memory
TOKEN_STORE_BACKEND=memory

# Required when TOKEN_STORE_BACKEND=convex.
# Deployment admin key used by ConvexHttpClient.setAdminAuth() to call internal mutations.
# Name can be CONVEX_DEPLOY_KEY (preferred) or CONVEX_ADMIN_KEY.
CONVEX_DEPLOY_KEY=

# SEC-08: Allow requests with no origin header (server-to-server, mobile apps)
# Set to false for stricter security posture
# Default: true (backward compatibility)
ALLOW_NO_ORIGIN=true

# =============================================================================
# KAPSO.AI WHATSAPP INTEGRATION (SRS v5)
# =============================================================================

# Kapso.ai API key for WhatsApp integration
# Required for sending messages to WhatsApp through Kapso
KAPSO_API_KEY=your-kapso-api-key

# Kapso.ai webhook secret token for signature validation
# Generate a secure random string and set it both here and in your Kapso webhook configuration
# Use: openssl rand -hex 32
KAPSO_WEBHOOK_SECRET=your-secure-webhook-secret-token
