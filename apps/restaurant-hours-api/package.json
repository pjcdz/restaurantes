{
  "name": "restaurant-hours-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "webhook:set": "tsx src/scripts/set-telegram-webhook.ts",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:webhook:set": "docker compose exec -e NGROK_API_URL=http://ngrok:4040/api/tunnels api node dist/scripts/set-telegram-webhook.js",
    "langfuse:setup": "echo 'Access LangFuse at http://localhost:3001 and create your project keys'"
  },
  "dependencies": {
    "@langchain/core": "^0.3.57",
    "@langchain/google-genai": "^0.2.9",
    "@langchain/langgraph": "^0.2.67",
    "convex": "^1.32.0",
    "express": "^5.1.0",
    "langfuse": "^3.37.0",
    "langfuse-langchain": "^3.37.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
